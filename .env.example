# ─── Core ─────────────────────────────────────────────────────────────────────
# Environment: development | production | test  (default: development)
NODE_ENV=development

# Server listening port  (default: 3000)
PORT=3000

# ─── Logging ──────────────────────────────────────────────────────────────────
# Pino log level: fatal | error | warn | info | debug | trace | silent
# Use "silent" in test environments to suppress all output.
# (default: info)
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection URI  (default: mongodb://localhost:27017/chain-verse)
# Local:  mongodb://localhost:27017/chain-verse
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/chain-verse
MONGO_URI=mongodb://localhost:27017/chain-verse

# Separate URI used only by the test runner (optional)
MONGODB_TEST_URI=mongodb://localhost:27017/chainverse_test

# ─── Authentication  ── REQUIRED ──────────────────────────────────────────────
# Must be at least 32 characters.  Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-secure-random-string-of-at-least-32-chars

# Certificate download token lifetimes (seconds)  (defaults: 3600 / 7200)
DOWNLOAD_TOKEN_EXPIRY=3600
BULK_DOWNLOAD_TOKEN_EXPIRY=7200

# ─── Email ────────────────────────────────────────────────────────────────────
# Use a Gmail app-password if 2FA is enabled on the account
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=noreply@chainverse.academy

# SMTP configuration (optional — if omitted, emails are logged but not sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ─── Application base URL ─────────────────────────────────────────────────────
# Used for callback links in emails, etc.  (default: http://localhost:3000)
BASE_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── Redis (optional – the app degrades gracefully without it) ────────────────
REDIS_URL=redis://localhost:6379
# Set to true to require Redis even when REDIS_URL is absent (default: false)
FORCE_REDIS=false

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# Guest (unauthenticated) requests
RATE_LIMIT_GUEST_WINDOW_MS=60000
RATE_LIMIT_GUEST_MAX=30

# Authenticated users
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=100

# Premium users
RATE_LIMIT_PREMIUM_WINDOW_MS=60000
RATE_LIMIT_PREMIUM_MAX=200

# Admin / moderator users
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=500

RATE_LIMIT_SKIP_SUCCESS=false
RATE_LIMIT_SKIP_FAILED=false
RATE_LIMIT_KEY_PREFIX=rl:
